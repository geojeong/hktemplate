\NeedsTeXFormat{LaTeX2e}[1999/12/01]
\ProvidesPackage{hktem}[2026/03/12 Simple report template inspired by CVPR]

% Engine check: hktem is intended for XeLaTeX or LuaLaTeX.
\RequirePackage{iftex}
\ifPDFTeX
  \PackageError{hktem}{hktem requires XeLaTeX or LuaLaTeX}{Please compile with XeLaTeX or LuaLaTeX.}
\fi

% Basic packages
\RequirePackage{fontspec}
\RequirePackage{kotex}
\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{amsmath}
\RequirePackage{amssymb}
\RequirePackage{booktabs}
\RequirePackage{caption}
\RequirePackage{subcaption}
\RequirePackage{enumitem}
\RequirePackage{titlesec}
\RequirePackage{fancyhdr}
\RequirePackage{microtype}
\RequirePackage{hyperref}
\RequirePackage{geometry}

% Page layout: CVPR-like but simplified
\geometry{
  paper=letterpaper,
  left=0.75in,
  right=0.75in,
  top=1.0in,
  bottom=1.0in,
  columnsep=0.3125in
}

% Fonts
\defaultfontfeatures{Ligatures=TeX}
\setmainfont{NanumMyeongjo}
\setsansfont{NanumGothic}
\setmonofont{Consolas}
\newfontfamily\englishfont{Times New Roman}

% Hyperref colors
\definecolor{hkblue}{rgb}{0.15,0.35,0.62}
\hypersetup{
  colorlinks=true,
  linkcolor=hkblue,
  citecolor=hkblue,
  urlcolor=hkblue,
  pdftitle={},
  pdfauthor={}
}

% General typography
\setlength{\parindent}{0pt}
\setlength{\parskip}{0.35em}
\linespread{1.3}
\captionsetup{font=small,labelfont=bf,labelsep=period}
\setlist[itemize]{topsep=2pt,itemsep=1pt,parsep=0pt,leftmargin=1.2em}
\setlist[enumerate]{topsep=2pt,itemsep=1pt,parsep=0pt,leftmargin=1.5em}

% Section styles
\titleformat{\section}{\large\bfseries}{\thesection.}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection.}{0.5em}{}
\titlespacing*{\section}{0pt}{0.8em}{0.35em}
\titlespacing*{\subsection}{0pt}{0.6em}{0.25em}

% Header / footer
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

% Title block
\makeatletter
\renewcommand{\maketitle}{
  \twocolumn[{%
    \begin{center}
      {\LARGE\bfseries \@title\par}
      \vspace{0.7em}
      {\large \@author\par}
      \vspace{0.8em}
    \end{center}
  }]
}
\makeatother

% Abstract environment (compact)
\renewenvironment{abstract}{%
  \begin{center}\bfseries Abstract\end{center}
  \small
}{\par\normalsize\vspace{0.5em}}

% Handy commands
\newcommand{\email}[1]{\texttt{#1}}
\newcommand{\code}[1]{\texttt{#1}}
\newcommand{\figref}[1]{Fig.~\ref{#1}}
\newcommand{\tabref}[1]{Table~\ref{#1}}
\newcommand{\secref}[1]{Section~\ref{#1}}

